{
  "manifest_version": 3,
  "name": "AppliedIn",
  "version": "2.1.5",
  "description": "Auto-track your job applications from LinkedIn, Naukri, Internshala and more. Built for Indian freshers.",
  "permissions": [
    "storage",
    "unlimitedStorage",
    "activeTab",
    "scripting",
    "tabs",
    "contextMenus",
    "alarms",
    "notifications"
  ],
  "host_permissions": [
    "https://www.linkedin.com/*",
    "https://www.naukri.com/*",
    "https://internshala.com/*",
    "https://*.indeed.com/*",
    "https://*.glassdoor.com/*",
    "https://*.glassdoor.co.in/*",
    "https://unstop.com/*",
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "commands": {
    "log-application": {
      "suggested_key": {
        "default": "Ctrl+Shift+L",
        "mac": "Command+Shift+L"
      },
      "description": "Log this page as a job application"
    }
  },
  "content_scripts": [
    {
      "matches": ["https://www.linkedin.com/*"],
      "js": ["content/common.js", "content/linkedin.js"]
    },
    {
      "matches": ["https://www.naukri.com/*"],
      "js": ["content/common.js", "content/naukri.js"]
    },
    {
      "matches": ["https://internshala.com/*"],
      "js": ["content/common.js", "content/internshala.js"]
    },
    {
      "matches": ["https://*.indeed.com/*"],
      "js": ["content/common.js", "content/indeed.js"],
      "all_frames": true
    },
    {
      "matches": ["https://*.glassdoor.com/*", "https://*.glassdoor.co.in/*"],
      "js": ["content/common.js", "content/glassdoor.js"],
      "all_frames": true
    },
    {
      "matches": ["https://unstop.com/*"],
      "js": ["content/common.js", "content/unstop.js"]
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["xlsx.full.min.js"],
      "matches": ["<all_urls>"]
    }
  ]
}